# Copy this file to deploy/forpsi-form.env and fill in real values.
# Never commit deploy/forpsi-form.env.

# FTP/FTPS host from Forpsi administration or welcome e-mail.
FORPSI_FTP_HOST=

# FTP user for the subdomain or hosting space.
FORPSI_FTP_USER=

# FTP password. Keep it only in this local env file.
FORPSI_FTP_PASS=

# Remote public directory for form.vratasnabl.cz.
FORPSI_FORM_REMOTE_DIR=/www

# Default is dry run. Set to 0 for real upload.
FORPSI_DRY_RUN=1
