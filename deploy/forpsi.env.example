# Copy this file to deploy/forpsi.env and fill in real values.
# Never commit deploy/forpsi.env.

# FTP/FTPS host from Forpsi administration or the welcome email.
# Example: ftp.example.forpsi.com
FORPSI_FTP_HOST=

# FTP login. For a single website FTP account it is often the domain with www prefix.
# Example: www.vratasnabl.cz
FORPSI_FTP_USER=

# FTP password. Keep it only in your local env file or in GitHub Secrets.
FORPSI_FTP_PASS=

# Remote directory for public web files.
# For a website FTP account use /www.
# For a main multihosting FTP account use /vratasnabl.cz/www.
FORPSI_REMOTE_DIR=/www

# Set to 1 only after checking the first dry run. It removes remote files
# that are no longer present locally, inside FORPSI_REMOTE_DIR.
FORPSI_DELETE_REMOTE=0

# Default is dry run. Set to 0 for real upload.
FORPSI_DRY_RUN=1
